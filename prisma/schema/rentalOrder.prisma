model RentalOrder {
    id          String            @id @default(uuid())
    customerId  String
    customer    User              @relation(fields: [customerId], references: [id])
    status      RentalStatus      @default(PENDING)
    totalAmount Float
    createdAt   DateTime          @default(now())
    updatedAt   DateTime          @updatedAt
    items       RentalOrderItem[]
    // payment Payment[]

    @@index([customerId])
    payments Payment[]
}
